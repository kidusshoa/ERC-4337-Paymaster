NODE_ENV="development"
# Using the 5010-5019 range (not 3000) to avoid clashing with other local projects.
PORT=5010

# modules/crypto — chain target for viem's PublicClient.
CHAIN_ID=31337
CHAIN_RPC_URL="http://127.0.0.1:8545"

# modules/crypto — SignerService backend. Only "local" is implemented; "kms" is a
# documented extension point in crypto.module.ts for a future AWS KMS-backed signer.
SIGNER_BACKEND="local"
# Anvil's well-known account #1 test key — never fund or reuse it on a real network.
# This is the key that signs paymasterAndData off-chain (see contracts/.env.example's
# VERIFYING_SIGNER_ADDRESS, which should be this key's corresponding address).
SIGNER_PRIVATE_KEY="0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d"

# modules/relayer — the relayer/bundler EOA that submits handleOps and pays its own
# gas. A distinct role (and, in production, a distinct key) from the paymaster
# signer above. Anvil's well-known account #2 test key.
RELAYER_PRIVATE_KEY="0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a"

# modules/redis, modules/queue — matches docker-compose.yml's remapped Redis port (6381).
REDIS_URL="redis://127.0.0.1:6381"
# Namespaces BullMQ's Redis keys — change this if you run more than one instance of
# this app against the same Redis (each e2e test file overrides it to its own value).
BULLMQ_PREFIX="bullmq"

# common/guards/rate-limit.guard — IP tier applies to every guarded route; wallet tier
# only applies to routes annotated with @RateLimitWalletField(...) (the sponsor
# endpoint, Phase 9, is the first consumer).
RATE_LIMIT_IP_MAX=50
RATE_LIMIT_IP_WINDOW_SECONDS=60
RATE_LIMIT_WALLET_MAX=5
RATE_LIMIT_WALLET_WINDOW_SECONDS=86400

# prisma/schema.prisma — matches docker-compose.yml's remapped Postgres port (5434).
DATABASE_URL="postgresql://paymaster:paymaster@localhost:5434/paymaster?schema=public"

# modules/paymaster — the deployed EntryPoint/VerifyingPaymaster this instance signs
# against. On Anvil these change every restart: run contracts' DeployPaymaster.s.sol
# (Phase 4) and paste the addresses it prints. Placeholders below are NOT real
# contracts — the sponsor endpoint's own unit/e2e tests don't call the chain, only
# Phase 10's dedicated on-chain test does, using its own freshly-deployed addresses.
ENTRY_POINT_ADDRESS="0x0000000071727De22E5E9d8BAf0edAc6f37da032"
PAYMASTER_CONTRACT_ADDRESS="0xdead0000dead0000dead0000dead0000dead0000"

# Gas this paymaster tells the EntryPoint to allot its own validatePaymasterUserOp
# (postOp is never invoked — see VerifyingPaymaster.sol's doc comment — so its limit
# is always 0 regardless of this being configurable).
PAYMASTER_VERIFICATION_GAS_LIMIT=100000
PAYMASTER_POSTOP_GAS_LIMIT=0

# How long a signed paymasterAndData remains valid before validUntil expiry.
SPONSOR_VALID_SECONDS=180

# modules/relayer — how long to wait after submitting before checking whether a
# handleOps transaction has been mined; if not, it's marked STUCK and resubmitted
# (same relayer nonce, bumped fees — a real EIP-1559 replacement) up to
# MAX_GAS_BUMP_ATTEMPTS times before giving up and marking it FAILED.
STUCK_CHECK_DELAY_SECONDS=45
GAS_BUMP_PERCENT=15
MAX_GAS_BUMP_ATTEMPTS=5
