# Used by DeployPaymaster.s.sol on both networks.
# VERIFYING_SIGNER_ADDRESS should be the address of the backend's SignerService key
# (modules/crypto, Phase 6) — the address that will sign paymasterAndData off-chain.
# For a local Anvil run, any test account works, e.g. Anvil account #1:
VERIFYING_SIGNER_ADDRESS="0x70997970C51812dc3A010C7d01b50e0d17dc79C8"
# Optional: fund the paymaster's EntryPoint deposit immediately after deploy (in wei).
# Leave at 0 to skip and fund manually later via `paymaster.deposit()`.
PAYMASTER_INITIAL_DEPOSIT_WEI="0"
